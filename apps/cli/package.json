{
  "name": "@opreturnsocial/cli",
  "version": "0.1.1",
  "description": "Agent-first CLI for the opreturn.social bitcoin social protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opreturnsocial/opreturn.social.git",
    "directory": "apps/cli"
  },
  "homepage": "https://opreturn.social",
  "keywords": [
    "bitcoin",
    "op_return",
    "social",
    "cli",
    "nostr",
    "lightning",
    "agent"
  ],
  "private": false,
  "type": "module",
  "bin": {
    "ors": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc && chmod 755 dist/index.js",
    "dev": "yarn build && ORS_FACILITATOR_URL=http://localhost:3002 ORS_CACHE_URL=http://localhost:3001 node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@opreturnsocial/protocol": "^0.1.0",
    "commander": "^14.0.0",
    "nostr-tools": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
