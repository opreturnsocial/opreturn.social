# Bitcoin Core RPC (Polar defaults)
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=polaruser
BITCOIN_RPC_PASS=polarpass

# Wallet name for fundrawtransaction/signrawtransactionwithwallet.
# In Polar, check wallet name (e.g. "alice"). Leave blank if only one wallet is loaded.
BITCOIN_RPC_WALLET=

# Cache server URL
CACHE_SERVER_URL=http://localhost:3001

# Server
FACILITATOR_PORT=3002

# SQLite database for pending broadcasts
DATABASE_URL=file:./dev.db

# NWC URL for receiving Lightning payments (hold invoices).
# The facilitator is the payment receiver - use the NWC URL of your receiving wallet.
NWC_URL=

# Fee markup percentage added on top of the on-chain fee (e.g., 10 = 10%)
FEE_MARKUP_PERCENT=10

# Hold invoice expiry in seconds (default: 600 = 10 minutes)
INVOICE_EXPIRY_SECS=600

# Shared secret sent to cache /notify (must match cache's CACHE_INTERNAL_TOKEN)
CACHE_INTERNAL_TOKEN=changeme

# Override fee rate per priority (sat/vByte). Useful on regtest.
# FORCE_FEE_RATE_HIGH_SAT_PER_VBYTE=1
# FORCE_FEE_RATE_MEDIUM_SAT_PER_VBYTE=0.1
# Override both priorities at once (legacy, lower precedence than per-priority overrides):
# FORCE_FEE_RATE_SAT_PER_VBYTE=1

# Allow broadcasting v0 transactions (can block utxos until transactions are mined)
ALLOW_BROADCAST_V0=false