datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

model Post {
  txid        String
  network     String  @default("mainnet")
  blockHeight Int
  timestamp   Int
  content     String
  kind        Int     @default(1)
  pubkey      String
  sig         String
  parentTxid  String?
  status      String  @default("confirmed")

  @@id([txid, network])
}

model ScannerState {
  network   String  @id
  lastBlock Int     @default(0)
}

model Profile {
  pubkey    String
  network   String  @default("mainnet")
  name      String?
  bio       String?
  avatarUrl String?
  bot       Boolean?
  status    String  @default("confirmed")

  @@id([pubkey, network])
}

model Follow {
  followerPubkey String
  followeePubkey String
  network        String  @default("mainnet")
  txid           String
  timestamp      Int
  blockHeight    Int
  isFollow       Boolean
  status         String  @default("confirmed")
  sig            String  @default("")

  @@id([followerPubkey, followeePubkey, network])
}

model ProfileUpdateEvent {
  txid         String
  network      String  @default("mainnet")
  pubkey       String
  propertyKind Int
  value        String
  blockHeight  Int
  timestamp    Int
  status       String @default("confirmed")
  sig          String @default("")

  @@id([txid, network])
}

model ScannedBlock {
  height  Int
  network String  @default("mainnet")
  hash    String

  @@id([height, network])
}

model PendingChunk {
  id          Int     @id @default(autoincrement())
  txid        String
  network     String  @default("mainnet")
  chunkNum    Int
  totalChunks Int?    // only set for chunkNum == 0
  bodySlice   String  // hex-encoded body slice
  blockHeight Int
  timestamp   Int     // block timestamp (unix)

  @@unique([txid, network])
}
