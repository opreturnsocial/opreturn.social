# Bitcoin Core RPC (Polar defaults)
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=polaruser
BITCOIN_RPC_PASS=polarpass

# Database
DATABASE_URL=file:./dev.db

# Server
CACHE_SERVER_PORT=3001

# START_BLOCK=0  # Set to first available block on pruned nodes (e.g. 800000)

# Shared secret for internal endpoints (must match facilitator's CACHE_INTERNAL_TOKEN)
CACHE_INTERNAL_TOKEN=changeme
