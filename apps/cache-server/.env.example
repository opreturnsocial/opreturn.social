# Bitcoin Core RPC (Polar defaults)
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=polaruser
BITCOIN_RPC_PASS=polarpass

# Database
DATABASE_URL=file:./dev.db

# Server
CACHE_SERVER_PORT=3001

# START_BLOCK=0  # Set to first available block on pruned nodes (e.g. 800000)

# Shared secret for internal endpoints (must match facilitator's CACHE_INTERNAL_TOKEN)
CACHE_INTERNAL_TOKEN=changeme

# Free network Bitcoin Core RPC (enables free network scanning - defaults to mutinynet)
# Set FREE_NETWORK to the network name stored in the DB (e.g. mutinynet, testnet4, signet)
# For Polar it doesn't matter (just point at a second polar network - you can run 2 at once)
FREE_NETWORK=mutinynet
FREE_NETWORK_BITCOIN_RPC_HOST=127.0.0.1
FREE_NETWORK_BITCOIN_RPC_PORT=38332
FREE_NETWORK_BITCOIN_RPC_USER=polaruser
FREE_NETWORK_BITCOIN_RPC_PASS=polarpass
# FREE_NETWORK_START_BLOCK=0  # Set to first available block on pruned nodes
