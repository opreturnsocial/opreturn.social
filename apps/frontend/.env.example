# Vite prefix required for browser-accessible env vars
VITE_FACILITATOR_URL=http://localhost:3002
VITE_CACHE_SERVER_URL=http://localhost:3001
# On-chain bitcoin addresses to display as donation targets on the settings page
# VITE_FACILITATOR_DONATION_ADDRESS=
# VITE_FACILITATOR_DONATION_ADDRESS_FREE_NETWORK=
# Allow broadcasting v0 transactions (can block utxos until transactions are mined)
VITE_ALLOW_BROADCAST_V0=false
# Free network name for display/mempool links (must match FREE_NETWORK in backend)
VITE_FREE_NETWORK=mutinynet
